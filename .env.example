DATABASE_URL=sqlite:///./quoteops.db

QUOTEOPS_ENV=local
QUOTEOPS_AUTH_SECRET=change-me-in-production
QUOTEOPS_DEMO_TOOLS_ENABLED=true
QUOTEOPS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LLM_ENABLED=false
OPENAI_MODEL=gpt-5-mini
# OPENAI_API_KEY=change-me-if-enabled

VITE_API_BASE_URL=http://127.0.0.1:8000

# Render/PostgreSQL example only. Do not commit real credentials.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Render frontend example only.
# VITE_API_BASE_URL=https://YOUR-BACKEND-URL.onrender.com
